# Copy to `.env` (gitignored) and fill in real values. The app loads .env at startup.
# Environment variables always override the file, so prod can inject these directly.

# Medha vision model (required for real runs)
MEDHA_API_KEY=your-medha-api-key-here
MEDHA_API_URL=http://your-medha-host:8002/v1

# PostgreSQL (durable queue + datastore)
DATABASE_URL=postgresql://user:password@localhost:5432/payment_verification

# Optional dashboard auth (set BOTH to require HTTP basic auth)
PV_AUTH_USER=
PV_AUTH_PASS=

# Optional tuning
WORKER_COUNT=8
TEST_TTL_DAYS=1
PV_SECRET_KEY=generate-with-python-secrets-token_hex-32
LEAD_EVENTS_TTL_DAYS=90          # event-log retention in continuous prod (0 = keep forever)

# ── Automated ingestion (OFF unless SOURCE_MODE is set) — see docs/INGESTION.md ──
# Pull new leads from the source DB behind Metabase, verify them, publish to Metabase.
SOURCE_MODE=                      # '' (off) | db | metabase
SOURCE_DATABASE_URL=              # SQLAlchemy URL, e.g. postgresql+psycopg://reader:pw@host:5432/db
#                                   (MySQL: mysql+pymysql://reader:pw@host:3306/db  — pip install pymysql)
SOURCE_MAPPING_PATH=              # defaults to config/source_mapping.json
INGEST_SOURCE_NAME=primary        # logical source name (its own watermark)
INGEST_INTERVAL=120               # seconds between poll cycles
INGEST_BATCH=500                  # rows per fetch page
INGEST_OVERLAP_MIN=10             # re-read window (clock skew / late commits); widen if source times are local
IMAGE_PREFETCH=1                  # download the doc at ingest time into the blob store
IMAGE_STORE_PATH=                 # defaults to data/blobs (mount an encrypted volume in prod)
IMAGE_RETENTION_DAYS=90           # blob retention (0 = forever)
BACKFILL_ROWS_PER_MIN=600         # rate cap so a historical backfill never starves the live tail
# Metabase source backend (only if SOURCE_MODE=metabase):
METABASE_URL=
METABASE_USER=
METABASE_PASS=
METABASE_CARD_ID=
