# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ── Virtual envs ────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets / local config ──────────────────────────────
.env
.env.*
.claude/settings.local.json

# ── Runtime data (regenerated per run) ──────────────────
data/logs/
data/uploads/
data/outputs/
data/verification.db

# ── OS / editor cruft ───────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# keep the folders themselves so the app's makedirs is a no-op
!data/uploads/.gitkeep
!data/outputs/.gitkeep

# keep the template (but never the real .env)
!.env.example

# machine-local Claude Code config — not part of the app
.claude/

# sample datasets contain REAL customer data — must never enter version control
samples/
